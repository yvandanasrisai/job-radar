# ── Job Alert Email ────────────────────────────────────────────────────────
# The Gmail address that SENDS the job alert emails to you
ALERT_EMAIL_ADDRESS=your_alert_gmail@gmail.com
# Gmail App Password (16-char, from Google Account > Security > App Passwords)
# Format with spaces: "xxxx xxxx xxxx xxxx"
ALERT_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# The address that RECEIVES the job alert emails (can be same as above)
MY_EMAIL=your_personal_email@gmail.com
MY_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Scoring ────────────────────────────────────────────────────────────────
# Minimum score (0–100) to trigger an email alert. Recommended: 55–70
SCORE_THRESHOLD=55

# ── Outreach System ────────────────────────────────────────────────────────
# Separate Gmail for cold outreach (recommended — keeps alert + outreach inboxes clean)
OUTREACH_EMAIL=your_outreach_gmail@gmail.com
OUTREACH_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Apollo.io API key for recruiter discovery (free tier: 50 credits/month)
# Leave empty to skip Apollo lookups
APOLLO_API_KEY=

# ── Your Profile ───────────────────────────────────────────────────────────
MY_NAME=Your Full Name
MY_FIRST_NAME=FirstName
MY_PHONE=(xxx) xxx-xxxx
MY_LINKEDIN=linkedin.com/in/your-linkedin-handle

# University name for alumni-based outreach (e.g. UTD alumni on LinkedIn)
UTD_SCHOOL_NAME=The University of Texas at Dallas

# ── Outreach Limits ────────────────────────────────────────────────────────
OUTREACH_MAX_PER_JOB=12
LINKEDIN_PER_COMPANY_CAP=10
LARGE_COMPANY_MAX=20
